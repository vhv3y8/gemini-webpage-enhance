{
  "manifest_version": 3,
  "name": "Gemini Chat Downloader",
  "version": "0.1.0",
  "description": "Download your Gemini chat history as Markdown.",
  "permissions": [
    "activeTab"
  ],
  "content_scripts": [
    {
      "matches": ["https://gemini.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
}
